  # Copy to .env on the server and fill in the values.                                                                                                     
  # Never commit .env to git.                                                                                                                              
                                               
  # ── Database ──────────────────────────────────────────────────────────────────                                                                         
  DATABASE_URL=postgres://gentax:CHANGE_ME@db:5432/gentax?sslmode=disable
                                                                                                                                                           
  # ── Telegram bot ──────────────────────────────────────────────────────────────
  TELEGRAM_BOT_TOKEN=CHANGE_ME                                                                                                                             
                                                   
  # ── Auth ──────────────────────────────────────────────────────────────────────                                                                         
  # Minimum 32 characters. Generate with: openssl rand -base64 48
  JWT_SECRET=CHANGE_ME                                                                                                                                     
                                                   
  # Secret required to call POST /auth/owner/bootstrap (first-time owner setup).                                                                           
  # Generate with: openssl rand -base64 24
  BOOTSTRAP_SECRET=CHANGE_ME                                                                                                                               
                                                   
  # ── Owner web panel ───────────────────────────────────────────────────────────
  # The public URL where the React panel is served (your Cloudflare domain).
  # Used by the API for CORS. No trailing slash.                                                                                                           
  CORS_ORIGIN=https://panel.tudominio.com
                                                                                                                                                           
  # ── OCR ───────────────────────────────────────────────────────────────────────                                                                         
  OCR_PROVIDER=tesseract                       
                                                                                                                                                           
  # ── Storage ───────────────────────────────────────────────────────────────────
  STORAGE_PROVIDER=local                       
  STORAGE_BUCKET=/data/receipts                                                                                                                            
   
  # ── App ───────────────────────────────────────────────────────────────────────                                                                         
  APP_ENV=production                               
  