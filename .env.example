# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gentax?sslmode=disable
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
JWT_SECRET=change-me-to-at-least-32-chars-long!!
OCR_PROVIDER=tesseract
STORAGE_PROVIDER=local
STORAGE_BUCKET=./uploads

# Optional (defaults shown)
APP_ENV=development
API_PORT=8080
BOT_POLL_TIMEOUT=60
OCR_WORKER_POOL_SIZE=3
OCR_POLL_INTERVAL_SECS=5

# Owner web panel
BOOTSTRAP_SECRET=changeme
CORS_ORIGIN=http://localhost:3000
WEB_PORT=3000

# Provider-specific (leave blank if not used)
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
